PORT=3000
NODE_ENV=development
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/social_manager?schema=public"

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Worker Configuration
WORKER_CONCURRENCY=2

# Batch Configuration (delays in milliseconds)
BATCH_DELAY_MIN=30000    # 30 seconds
BATCH_DELAY_MAX=300000   # 5 minutes
