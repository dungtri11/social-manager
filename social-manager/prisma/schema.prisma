// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CookieStatus {
  ACTIVE
  EXPIRED
  CHECKPOINT
}

enum RiskEventType {
  IP_CHANGE
  UA_CHANGE
  CHECKPOINT
  LOGIN_FAIL
}

enum RiskSeverity {
  LOW
  MEDIUM
  HIGH
}

model Proxy {
  id               String            @id @default(cuid())
  host             String
  port             Int
  username         String?
  password         String?
  createdAt        DateTime          @default(now())
  accounts         Account[]
  identityProfiles IdentityProfile[]
  proxyUsageLogs   ProxyUsageLog[]

  @@map("proxies")
}

model Account {
  id              String  @id @default(cuid())
  username        String  @unique
  userAgent       String
  proxyId         String?
  sessionDuration Int?    @default(30) // Session duration in minutes

  proxy      Proxy?      @relation(fields: [proxyId], references: [id])
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  actionLogs ActionLog[]

  // Identity Manager relations
  identityProfile IdentityProfile?
  cookieSessions  CookieSession[]
  proxyUsageLogs  ProxyUsageLog[]
  riskEvents      RiskEvent[]

  @@map("accounts")
}

model ActionLog {
  id         String   @id @default(cuid())
  accountId  String
  account    Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  actionType String // 'like', 'comment', 'share', 'follow'
  targetUrl  String?
  status     String // 'success', 'failed'
  errorMsg   String?
  executedAt DateTime @default(now())

  @@index([accountId])
  @@index([accountId, executedAt])
  @@index([actionType])
  @@map("action_logs")
}

// Identity Manager Tables

model IdentityProfile {
  id              String   @id @default(uuid())
  accountId       String   @unique
  account         Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  userAgent       String
  proxyId         String?
  proxy           Proxy?   @relation(fields: [proxyId], references: [id])
  timezone        String
  fingerprintHash String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([accountId])
  @@index([fingerprintHash])
  @@map("identity_profiles")
}

model CookieSession {
  id              String       @id @default(uuid())
  accountId       String
  account         Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  cookies         Json
  status          CookieStatus @default(ACTIVE)
  lastValidatedAt DateTime?
  createdAt       DateTime     @default(now())

  @@index([accountId])
  @@index([status])
  @@map("cookie_sessions")
}

model ProxyUsageLog {
  id        String   @id @default(uuid())
  proxyId   String
  proxy     Proxy    @relation(fields: [proxyId], references: [id], onDelete: Cascade)
  accountId String
  account   Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  usedAt    DateTime @default(now())
  ipAddress String?

  @@index([proxyId])
  @@index([accountId])
  @@index([usedAt])
  @@map("proxy_usage_logs")
}

model RiskEvent {
  id        String        @id @default(uuid())
  accountId String
  account   Account       @relation(fields: [accountId], references: [id], onDelete: Cascade)
  type      RiskEventType
  severity  RiskSeverity
  metadata  Json?
  createdAt DateTime      @default(now())

  @@index([accountId])
  @@index([severity])
  @@index([createdAt])
  @@map("risk_events")
}
