{
  "name": "social-manager",
  "version": "1.0.0",
  "description": "Multi-Account Social Media Management System",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "worker": "ts-node-dev --respawn --transpile-only src/worker.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:worker": "node dist/worker.js"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "bullmq": "^5.71.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "ioredis": "^5.10.0",
    "pg": "^8.20.0",
    "playwright": "^1.58.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/ioredis": "^4.28.10",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.18.0",
    "prisma": "^7.5.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  }
}
